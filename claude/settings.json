{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/tab-notify.sh mark; afplay -v 0.4 ~/.claude/sounds/notification.mp3",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/tab-notify.sh mark; afplay -v 0.4 ~/.claude/sounds/notification.mp3",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/tab-notify.sh clear",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "cl-asana@cclab": true,
    "gws@gws-marketplace": true,
    "yio@yio-skills": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cclab": {
      "source": {
        "source": "github",
        "repo": "chatbotgang/cclab"
      }
    },
    "gws-marketplace": {
      "source": {
        "source": "git",
        "url": "https://github.com/WadeWarren/gws-claude-plugin.git"
      }
    },
    "yio-skills": {
      "source": {
        "source": "github",
        "repo": "yiochou/yio-skills"
      }
    }
  },
  "tui": "fullscreen",
  "preferredNotifChannel": "ghostty",
  "model": "claude-fable-5[1m]"
}
